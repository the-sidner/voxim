{
  "id": "humanoid_default",
  "layers": [
    {
      "id": "reaction",
      "kind": "reaction",
      "output": "animation",
      "mask": "upper_body",
      "priority": 10,
      "initial": "none",
      "states": {
        "none": {
          "clip": null
        },
        "hit_front": {
          "clip": "$hit_front",
          "loop": false,
          "duration": 0.5
        },
        "hit_back": {
          "clip": "$hit_back",
          "loop": false,
          "duration": 0.5
        },
        "stagger.light": {
          "clip": "$stagger_light",
          "loop": false,
          "duration": 0.4,
          "mask": "",
          "tags": [
            "locks_input",
            "locks_facing"
          ]
        },
        "stagger.heavy": {
          "clip": "$stagger_heavy",
          "loop": false,
          "duration": 0.7,
          "mask": "",
          "tags": [
            "locks_input",
            "locks_facing"
          ]
        },
        "death": {
          "clip": "$death",
          "loop": false,
          "duration": 1.5,
          "mask": "",
          "tags": [
            "locks_input",
            "locks_facing"
          ]
        }
      },
      "transitions": [
        {
          "to": "death",
          "when": "health.current <= 0",
          "priority": 100
        },
        {
          "to": "stagger.heavy",
          "when": "event.stagger.heavy",
          "priority": 60
        },
        {
          "to": "stagger.light",
          "when": "event.stagger.light",
          "priority": 50
        },
        {
          "to": "hit_front",
          "when": "event.hit.from_front"
        },
        {
          "to": "hit_back",
          "when": "event.hit.from_back"
        },
        {
          "from": [
            "hit_front",
            "hit_back",
            "stagger.light",
            "stagger.heavy"
          ],
          "to": "none",
          "when": "state.elapsed >= state.duration"
        }
      ]
    }
  ]
}
