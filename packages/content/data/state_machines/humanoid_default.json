{
  "id": "humanoid_default",
  "layers": [
    {
      "id": "right_hand",
      "kind": "action",
      "output": "animation",
      "mask": "right_arm",
      "priority": 1,
      "initial": "idle",
      "states": {
        "idle":           { "clip": null },
        "swing.windup":   { "clip": "$weapon.swing_clip", "loop": true,  "mask": "upper_body", "duration": 5.0,
                            "tags": ["action", "carries_swing_context"] },
        "swing.stop":     { "clip": "$weapon.swing_clip", "loop": false, "mask": "upper_body", "duration": 0.08,
                            "tags": ["action", "carries_swing_context", "chain_queueable"] },
        "swing.active":   { "clip": "$weapon.swing_clip", "loop": false, "mask": "upper_body", "duration": "$action.active_seconds",
                            "tags": ["action", "carries_swing_context", "chain_queueable", "active_hitbox"] },
        "swing.winddown": { "clip": "$weapon.swing_clip", "loop": false, "mask": "upper_body", "duration": "$action.winddown_seconds",
                            "tags": ["action", "carries_swing_context", "chain_queueable"] },
        "block":          { "clip": "$weapon.block_clip", "loop": true },
        "aim":            { "clip": "$weapon.aim_clip",   "loop": true },
        "shoot":          { "clip": "$weapon.shoot_clip", "loop": false, "duration": 0.4 },
        "in_maneuver":    { "clip": null, "loop": false, "mask": "upper_body" }
      },
      "transitions": [
        { "from": "idle",            "to": "swing.windup",   "when": "event.swing_started", "priority": 50 },
        { "from": "swing.windup",    "to": "idle",           "when": "input.block",                         "priority": 100 },
        { "from": "swing.windup",    "to": "swing.stop",     "when": "!input.use_skill",                    "priority": 60 },
        { "from": "swing.windup",    "to": "swing.stop",     "when": "state.elapsed >= state.duration" },
        { "from": "swing.stop",      "to": "swing.active",   "when": "state.elapsed >= state.duration" },
        { "from": "swing.active",    "to": "swing.winddown", "when": "state.elapsed >= state.duration" },
        { "from": "swing.winddown",  "to": "idle",           "when": "state.elapsed >= state.duration" },
        { "from": "idle",  "to": "block", "when": "input.block" },
        { "from": "block", "to": "idle",  "when": "!input.block" },
        { "from": "idle",  "to": "aim",   "when": "input.aim && weapon.has_aim" },
        { "from": "aim",   "to": "shoot", "when": "event.shoot_fired" },
        { "from": "shoot", "to": "aim",   "when": "state.elapsed >= state.duration && input.aim" },
        { "from": "shoot", "to": "idle",  "when": "state.elapsed >= state.duration && !input.aim" },
        { "from": "aim",   "to": "idle",  "when": "!input.aim" },
        { "from": "idle",        "to": "in_maneuver", "when": "event.maneuver_started", "priority": 75 },
        { "from": "in_maneuver", "to": "idle",        "when": "event.maneuver_ended",   "priority": 75 }
      ]
    },
    {
      "id": "left_hand",
      "kind": "action",
      "output": "animation",
      "mask": "left_arm",
      "priority": 1,
      "initial": "idle",
      "states": {
        "idle":        { "clip": null },
        "in_maneuver": { "clip": null, "loop": false, "mask": "left_arm" }
      },
      "transitions": [
        { "from": "idle",        "to": "in_maneuver", "when": "event.maneuver_started", "priority": 75 },
        { "from": "in_maneuver", "to": "idle",        "when": "event.maneuver_ended",   "priority": 75 }
      ]
    },
    {
      "id": "reaction",
      "kind": "reaction",
      "output": "animation",
      "mask": "upper_body",
      "priority": 10,
      "initial": "none",
      "states": {
        "none":          { "clip": null },
        "hit_front":     { "clip": "$hit_front",     "loop": false, "duration": 0.5 },
        "hit_back":      { "clip": "$hit_back",      "loop": false, "duration": 0.5 },
        "stagger.light": { "clip": "$stagger_light", "loop": false, "duration": 0.4, "mask": "", "tags": ["locks_input", "locks_facing"] },
        "stagger.heavy": { "clip": "$stagger_heavy", "loop": false, "duration": 0.7, "mask": "", "tags": ["locks_input", "locks_facing"] },
        "death":         { "clip": "$death",         "loop": false, "duration": 1.5, "mask": "", "tags": ["locks_input", "locks_facing"] }
      },
      "transitions": [
        { "to": "death",         "when": "health.current <= 0",     "priority": 100 },
        { "to": "stagger.heavy", "when": "event.stagger.heavy",     "priority": 60 },
        { "to": "stagger.light", "when": "event.stagger.light",     "priority": 50 },
        { "to": "hit_front",     "when": "event.hit.from_front" },
        { "to": "hit_back",      "when": "event.hit.from_back" },
        { "from": ["hit_front", "hit_back", "stagger.light", "stagger.heavy"], "to": "none", "when": "state.elapsed >= state.duration" }
      ]
    }
  ]
}
