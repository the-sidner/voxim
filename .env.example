# Voxim2 environment — copy to .env (gitignored).
# Every variable referenced by docker-compose.yml or docker-compose.prod.yml
# is listed below. Defaults shown work for local dev as-is; sections marked
# "production only" must be reviewed before deploying.

# === Core (used by both compose files) ===

# Postgres credentials. Used by every voxim service.
POSTGRES_PASSWORD=voxim_dev_password
DATABASE_URL=postgres://voxim:voxim_dev_password@postgres:5432/voxim

# Shared secret between gateway, coordinator, and tile-servers. Min 16
# chars. Generate one with: openssl rand -base64 32. In production
# (VOXIM_ENV=production) services refuse to boot if this is unset (T-258).
VOXIM_SERVICE_SECRET=replace-me-with-a-long-random-string

# Deployment mode. "production" makes services fail closed when the service
# secret is unset. The prod compose defaults this to "production"; leave
# unset for local dev (services fall back to a dev-only secret).
# VOXIM_ENV=production

# Internal docker-network URLs the voxim services use to reach each other.
# Identical in dev and prod — these are docker DNS names, not public hosts.
GATEWAY_URL=http://gateway:8081
GATEWAY_WT_URL=https://gateway:8080

# Hostname / IP the browser uses for direct WebTransport to the tile
# servers. The gateway hands this address to the client in its tile-assign
# response, so it must be reachable from the user's browser.
#   - "127.0.0.1" for local dev
#   - your LAN IP for cross-device testing
#   - your public DNS name (= VOXIM_DOMAIN below) in production
HOST_ADDR=127.0.0.1

# === World generation ===

# Seed for the macro map. Changing this regenerates the world layout —
# wipe the postgres volume afterwards or old tile data will not line up.
WORLD_SEED=1

# Bootstrap world dimensions in tiles. Atlas auto-bakes a "world #1" with
# these values if the database is empty.
WORLD_NAME=bootstrap
WORLD_WIDTH=2
WORLD_HEIGHT=2
# Tile IDs the coordinator simulates. Must equal WORLD_WIDTH × WORLD_HEIGHT.
WORLD_TILES=tile_0,tile_1,tile_2,tile_3

# Macro tick rate (Hz) of the coordinator's world simulation.
COORDINATOR_TICK_RATE=1

# === Dev only (docker-compose.yml) ===

# Host port to publish postgres on. Set e.g. to 5433 if 5432 is taken.
# Inter-container traffic ignores this. The prod compose does not publish
# postgres at all (no `ports:` entry), so this variable is unused there.
POSTGRES_HOST_PORT=5432

# === Production only (docker-compose.prod.yml) ===

# Container image source. Pre-built images from
# .github/workflows/docker-publish.yml live under
# ghcr.io/<owner>/voxim/<service>. Override if you mirror images.
VOXIM_IMAGE_REPO=ghcr.io/the-sidner/voxim
# Pin to a specific build with VOXIM_TAG=sha-<short>. Defaults to :latest,
# which the workflow updates on every push to main.
VOXIM_TAG=latest

# Public DNS name pointed at this host. Caddy serves the client bundle and
# the /gateway + /account API on https://${VOXIM_DOMAIN} and provisions a
# Let's Encrypt cert automatically. Set HOST_ADDR above to the same value
# so tile WebTransport connections terminate on this host.
VOXIM_DOMAIN=voxim.4npserver.com
# Contact email for Let's Encrypt (used for expiry warnings). Optional;
# if empty, Caddy logs a warning but cert issuance still works.
ACME_EMAIL=

# Host interface that public-facing services bind to. Public surface:
#   - caddy 80 + 443/tcp + 443/udp   (HTTPS edge for client + API)
#   - tile-N 4433-4436/udp            (per-tile WebTransport)
# Loopback-only (127.0.0.1, hardcoded in compose): atlas 8082, coordinator
# 8083, tile-N admin 14433-14436. Reach via SSH tunnel.
# Internal-only (no host port): postgres, gateway HTTP 8081, gateway WT
# 8080, client-dev 3000.
#
# Default 0.0.0.0 = every interface. Set to a single public IP on a
# multi-homed box. Set to 127.0.0.1 to make the stack loopback-only (e.g.
# when fronting with another host-side reverse proxy).
BIND_IP=0.0.0.0
