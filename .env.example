# Voxim2 environment — copy to .env (gitignored) for local dev.

# --- Postgres ---
POSTGRES_PASSWORD=voxim_dev_password
# Inside compose: hostname `postgres`, port 5432.
DATABASE_URL=postgres://voxim:voxim_dev_password@postgres:5432/voxim
# Host port to publish Postgres on. Set to e.g. 5433 if you already run a
# Postgres on 5432. Doesn't affect inter-container traffic, only host-side
# tools (psql, the host-run `deno task migrate`).
POSTGRES_HOST_PORT=5432

# --- Service mesh ---
# Shared secret between gateway, coordinator, and tile-servers. Min 16 chars.
# Generate one with: openssl rand -base64 32
VOXIM_SERVICE_SECRET=replace-me-with-a-long-random-string

# Gateway URL the tile-servers use to reach the gateway over plain HTTP.
# Inside docker compose this is the service hostname; from the host it's
# localhost:8081.
GATEWAY_URL=http://gateway:8081

# Gateway WebTransport URL — used by the coordinator (and, post-T-139, by
# tile-servers for the privileged event/command stream).
GATEWAY_WT_URL=https://gateway:8080

# Hostname / IP the browser will connect to for direct WT-to-tile
# connections. Use 127.0.0.1 for local dev, or your LAN IP for cross-device
# testing.
HOST_ADDR=127.0.0.1

# Seed for world generation (coordinator). Change to regenerate the macro
# world map (which means wiping the postgres volume — old tiles will not
# match the new map).
WORLD_SEED=1

# --- Image source (docker-compose.prod.yml only) ---
# Pre-built images from .github/workflows/docker-publish.yml live under
# ghcr.io/<owner>/voxim/<service>. Override the repo if you mirror images
# to your own registry.
VOXIM_IMAGE_REPO=ghcr.io/the-sidner/voxim
# Pin to a specific build with VOXIM_TAG=sha-<short>. Defaults to :latest,
# which the workflow updates on every push to main.
VOXIM_TAG=latest
